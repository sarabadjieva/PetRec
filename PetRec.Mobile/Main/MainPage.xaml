<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PetRec.Mobile.Main.MainPage"
             xmlns:main="clr-namespace:PetRec.Mobile.Main">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">

            <CollectionView x:Name="PetsListView"
                            SemanticProperties.Hint="List of pets in the registry"
                            WidthRequest="100"
                            ItemsSource="{Binding Pets}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="main:PetViewModel">
                        <VerticalStackLayout HorizontalOptions="Center"
                                             VerticalOptions="Center">
                                <Button HorizontalOptions="Center"
                                        HeightRequest="100"
                                        WidthRequest="100"
                                        Margin="0,5"
                                        BackgroundColor="White"
                                        Command="{Binding SelectPetCommand,
                                        Source={RelativeSource AncestorType={x:Type main:MainPageViewModel}}}"
                                        CommandParameter="{Binding Id}"
                                        ImageSource="{Binding Image}"
                                        CornerRadius="100"/>
                            <Label Text="{Binding Name}" HorizontalTextAlignment="Center"/>
                            <Label Text="{Binding Id}" HorizontalTextAlignment="Center"/>
                            <Label Text="{Binding Type}" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button
                x:Name="AddPetBtn"
                Text="{Binding AddPetBtnText}" 
                SemanticProperties.Hint="Adds pet to registry"
                Command="{Binding AddPetCommand}"
                HorizontalOptions="Fill" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
